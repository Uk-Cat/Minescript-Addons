{
	"schemaVersion": 1,
	"id": "minescript-addons",
	"version": "${version}",
	"name": "Minescript Addons",
	"description": "Download Minescript scripts from GitHub repos with one click. Browse curated scripts or paste any GitHub repo URL.",
	"authors": [
		"Uk-Cat"
	],
	"contact": {
		"homepage": "https://github.com/Uk-Cat/Minescript-Addons",
		"sources": "https://github.com/Uk-Cat/Minescript-Addons"
	},
	"license": "MIT",
	"icon": "assets/minescript-addons/icon.png",
	"environment": "client",
	"mixins": [
		"minescript-addons.client.mixins.json"
	],
	"entrypoints": {
		"main": [
			"com.minescript.addons.MinescriptAddonsMod"
		],
		"client": [
			"com.minescript.addons.client.MinescriptAddonsClient"
		],
		"modmenu": [
			"com.minescript.addons.MinescriptAddonsMenu"
		]
	},
	"depends": {
		"fabricloader": ">=0.16.0",
		"minecraft": ">=1.21 <27",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"modmenu": "*"
	}
}
